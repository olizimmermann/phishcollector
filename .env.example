# Copy this file to .env and adjust values

# PostgreSQL connection (used inside Docker; change host if running outside)
PHISH_DATABASE_URL=postgresql+asyncpg://phish:phish@db:5432/phishcollector

# Optional API key — if set, every request must include header: X-API-Key: <value>
# Leave empty to disable authentication (useful for local / air-gapped use)
PHISH_API_KEY=

# Storage path for screenshots, HTML dumps, and downloaded assets
PHISH_DATA_DIR=/data

# Browser timeout in milliseconds (per page load)
PHISH_BROWSER_TIMEOUT=30000

# HTTP request timeout in seconds (for fingerprinting sub-requests)
PHISH_REQUEST_TIMEOUT=15

# Maximum pages the spider will visit per collection job
PHISH_MAX_SPIDER_PAGES=50

# Maximum size (bytes) for an asset file to be downloaded and stored
PHISH_MAX_ASSET_SIZE=10485760

# ── Proxy ────────────────────────────────────────────────────────────────────
# Route all outbound connections through this proxy so your real IP is not
# exposed to phishing servers.  Supports http/https/socks5.
# Example (Tor):    PHISH_PROXY_URL=socks5://127.0.0.1:9050
# Example (Burp):   PHISH_PROXY_URL=http://127.0.0.1:8080
# Leave empty for direct connections.
PHISH_PROXY_URL=

# Burp Suite (and other intercepting proxies) present their own CA certificate
# for every TLS connection.  Set this to false when using such a proxy,
# otherwise ALL HTTPS requests through the proxy will fail with an SSL error.
# WARNING: only set to false in a controlled analyst environment.
PHISH_PROXY_SSL_VERIFY=true

# ── Threat-intelligence plugins ───────────────────────────────────────────────
# URLhaus (abuse.ch) — free, no key required.  Set to true to enable.
PHISH_URLHAUS_ENABLED=false

# VirusTotal — requires a free or paid API key from https://www.virustotal.com
# Leave empty to disable.
PHISH_VIRUSTOTAL_API_KEY=
